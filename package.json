{
  "name": "@nais/apm",
  "version": "0.3.0",
  "description": "Opinionated @grafana/faro-web-sdk wrapper with a Sentry-like DX for applications on nais",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nais/apm.git"
  },
  "homepage": "https://github.com/nais/apm#readme",
  "bugs": {
    "url": "https://github.com/nais/apm/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "dependencies": {
    "@grafana/faro-web-sdk": "^2.8.2",
    "@grafana/faro-web-tracing": "2.8.2",
    "@grafana/rrweb": "2.0.0-grafana.2",
    "@grafana/rrweb-snapshot": "2.0.0-grafana.2",
    "fflate": "^0.8.3"
  },
  "peerDependencies": {
    "@grafana/faro-react": "^2.8.2",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "react-router": ">=6.0.0",
    "react-router-dom": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "@grafana/faro-react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-router": {
      "optional": true
    },
    "react-router-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@grafana/faro-react": "2.8.2",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.25.0",
    "jsdom": "^26.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.25.0"
}
